# ─────────────────────────────────────────
#  JioSaavn Bot — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── Telegram API credentials ──────────────
# Get from https://my.telegram.org/apps
API_ID=
API_HASH=

# ── Bot Token ─────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=

# ── MongoDB (optional but recommended) ────
# Free cluster: https://www.mongodb.com/cloud/atlas
DATABASE_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# ── Render keep-alive URL ─────────────────
# After deploying, paste your Render app URL here
# e.g. https://jiosaavn-bot.onrender.com
# This prevents the free-tier service from sleeping
RENDER_URL=

# ── Server config (leave defaults for Render) ──
HOST=0.0.0.0
PORT=10000
PING_INTERVAL=600
